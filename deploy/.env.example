APP_NAME=ztnet-custom
HTTP_PORT=3000
PUBLIC_BIND=127.0.0.1
APP_SUBNET=172.31.255.0/29

# Use your fork image after GitHub Actions publishes it.
ZTNET_IMAGE=ghcr.io/csbsgyl/ztnet-custom:latest
ZEROTIER_IMAGE=zyclonite/zerotier:1.14.2
POSTGRES_IMAGE=postgres:15.2-alpine
UPDATER_IMAGE=nickfedor/watchtower@sha256:c1dfdf27fe805dcfefe1cf048cee6960a511c097a99aa355b0bc4be6e6bb3bdf

# Check the ZTNET application image every hour and update it in the background.
# The profile controls whether the Docker-socket updater container is created.
COMPOSE_PROFILES=auto-update
AUTO_UPDATE=true
AUTO_UPDATE_INTERVAL=3600
AUTO_UPDATE_CLEANUP=false
UPDATE_API_URL=http://updater:8080
UPDATE_API_TOKEN=change_this_to_a_strong_random_value
RESTART_API_URL=http://restart-helper:8081
# Must be at least 32 characters and different from UPDATE_API_TOKEN.
RESTART_API_TOKEN=change_this_to_a_different_strong_random_value
RESTART_HELPER_IMAGE=ghcr.io/csbsgyl/ztnet-custom@sha256:b36809cd64857f8bd95dc6865960b772cf2d2bf1258296c05ebbd0d4e843cb84
RESTART_HELPER_SOURCE_SHA256=1038d5e16856ad5bed50d987f01cb57b666b61c85d531e01a5da17bd4ad28fa0
BACKUP_DIR=/app/backups

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_to_a_strong_random_value
POSTGRES_DB=ztnet
POSTGRES_PORT=5432

# Keep the first start on loopback and connect through an SSH tunnel.
NEXTAUTH_URL=http://127.0.0.1:3000
NEXTAUTH_SECRET=change_this_to_a_strong_random_value

# Required for OAuth-only bootstrap: only this normalized email may become the first admin.
INITIAL_ADMIN_EMAIL=

# Set true only when all requests arrive through a trusted reverse proxy that overwrites X-Forwarded-For.
RATE_LIMIT_TRUST_PROXY=false
