APP_NAME=ztnet-custom
HTTP_PORT=3000
APP_SUBNET=172.31.255.0/29

# Use your fork image after GitHub Actions publishes it.
ZTNET_IMAGE=ghcr.io/csbsgyl/ztnet-custom:latest
ZEROTIER_IMAGE=zyclonite/zerotier:1.14.2
POSTGRES_IMAGE=postgres:15.2-alpine
UPDATER_IMAGE=nickfedor/watchtower:1.19.0

# Check the ZTNET image digest every hour and update it in the background.
AUTO_UPDATE=true
AUTO_UPDATE_INTERVAL=3600
AUTO_UPDATE_CLEANUP=false
UPDATE_API_URL=http://updater:8080
UPDATE_API_TOKEN=change_this_to_a_strong_random_value
BACKUP_DIR=/app/backups

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_to_a_strong_random_value
POSTGRES_DB=ztnet
POSTGRES_PORT=5432

# Must match the URL users open in their browser.
NEXTAUTH_URL=http://your-server-ip:3000
NEXTAUTH_SECRET=change_this_to_a_strong_random_value
